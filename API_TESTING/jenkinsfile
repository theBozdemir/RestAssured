pipeline{
    agent any
    environment{
        BASE_URL='https://rahulshettyacademy.com'
    }
    stages{
        stage("Checkout"){
            steps{
                git branch: 'main',
                url: "https://github.com/theBozdemir/RestAssured.git"
            }
        }
        stage("Run Cucumber tests"){
            steps{
                script {
                    def mvnCmd = "cd API_TESTING && mvn clean -Pcucumber-report -Dtest=TestRunnerCucumber test verify"
                    if (isUnix()) {
                        sh mvnCmd
                    } else {
                        bat mvnCmd
                    }
                }
            }
        }
    }
}